# ============================================================================
# MessageForge Environment Variables Template
# Copy to .env and fill in your actual values
# ============================================================================

# DATABASE CONFIGURATION
# PostgreSQL connection details
DB_URL=jdbc:postgresql://localhost:5432/messageforge
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT CONFIGURATION
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=your-super-secret-key-change-this-in-production-min-64-chars-here
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# ENCRYPTION CONFIGURATION
# Generate: openssl rand -hex 16 (32 chars for AES-256)
ENCRYPTION_KEY=your-32-character-encryption-key-12345

# REDIS CONFIGURATION
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RABBITMQ CONFIGURATION
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# EMAIL INTEGRATION - Mailgun
# Get API key from: https://app.mailgun.com/app/account/security/api_keys
MAILGUN_API_KEY=key-your-mailgun-api-key-here
MAILGUN_DOMAIN=sandboxXXX.mailgun.org

# SMS INTEGRATION - Twilio
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE=+1234567890

# MESSAGING INTEGRATION - Meta (Facebook/WhatsApp)
# Get from: https://developers.facebook.com
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# PROFESSIONAL NETWORK - LinkedIn
# Get from: https://www.linkedin.com/developers/apps
LINKEDIN_ACCESS_TOKEN=your-linkedin-token

# COLLABORATION - Slack
# Get from: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret

# SOCIAL MEDIA - Twitter/X
# Get from: https://developer.twitter.com
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# APPLICATION CONFIGURATION
SERVER_PORT=8080
FRONTEND_URL=http://localhost:3000

# PRODUCTION ONLY - SSL/HTTPS
SSL_KEYSTORE_PATH=/path/to/keystore.p12
SSL_KEYSTORE_PASSWORD=your-keystore-password

# LOGGING
LOG_LEVEL=INFO
LOG_FORMAT=json

# SENTRY (Error Tracking) - Optional
SENTRY_DSN=

# DATADOG (Monitoring) - Optional
DATADOG_API_KEY=
DATADOG_APP_KEY=

# FEATURE FLAGS
EMAIL_ENABLED=true
SMS_ENABLED=true
FACEBOOK_ENABLED=true
WHATSAPP_ENABLED=true
LINKEDIN_ENABLED=true
SLACK_ENABLED=true
TWITTER_ENABLED=true
TELEGRAM_ENABLED=true
